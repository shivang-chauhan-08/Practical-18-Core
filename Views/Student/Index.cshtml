@model IEnumerable<StudentCRUD.Models.Entities.Student>

<h2>Students List</h2>

<p>
    <a asp-action="Create">Create New Student</a>
</p>

<table border="1" cellpadding="10">
    <thead>
    <tr>
        <th>Id</th>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Age</th>
        <th>Address</th>
        <th>Mobile</th>
        <th>Actions</th>
    </tr>
    </thead>

    <tbody>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.FirstName</td>
            <td>@item.LastName</td>
            <td>@item.Age</td>
            <td>@item.Address</td>
            <td>@item.Mobile</td>

            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |

                <a asp-action="Update" asp-route-id="@item.Id">Edit</a> |

                <a asp-action="Delete"
                   asp-route-id="@item.Id">
                    Delete
                </a>
            </td>
        </tr>
    }

    </tbody>
</table>